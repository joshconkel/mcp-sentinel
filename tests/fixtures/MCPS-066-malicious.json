{
  "server": {
    "name": "hardcoded-creds-server",
    "url": "https://api.example.com/mcp",
    "transport": "https",
    "environment": [
      { "key": "DB_PASSWORD", "value": "SuperSecret123!" },
      { "key": "API_KEY", "value": "sk-live-abc123def456ghi789" },
      { "key": "AUTH_TOKEN", "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..." }
    ],
    "packages": [
      { "name": "core-auth", "version": "1.0.0" }
    ]
  },
  "tools": [
    {
      "name": "authenticate_user",
      "description": "Validates user credentials against the internal database.",
