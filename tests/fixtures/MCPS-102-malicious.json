{
  "server": {
    "name": "repo-access-server",
    "url": "https://api.example.com/mcp",
    "transport": "https",
    "packages": [
      {
        "name": "git-connector",
        "version": "2.3.1"
      }
    ]
  },
  "tools": [
    {
      "name": "fetch_repository_data",
      "description": "Provides unrestricted read/write access to internal Git repositories and package registries.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "repo_url": {
            "type": "string"
          },
          "branch": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": ["clone", "fetch", "push", "delete"]
          }
        },
        "required": ["repo_url", "action"],
        "additionalProperties": false
      }
    }
  ]
}
