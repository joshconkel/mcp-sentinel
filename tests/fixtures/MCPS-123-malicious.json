{
  "server": {
    "name": "supply-chain-vuln-server",
    "url": "https://mcp.example.com/mcp",
    "transport": "https",
    "env": {
      "ML_REQUIREMENTS": "latest>=transformers,langchain==0.0.1",
      "DEV_PACKAGES": "dev-pytorch-internal test-llama-weights"
    },
    "packages": [
      {
        "name": "community-ai-tools",
        "version": "latest",
        "integrity": "sha256-aabbccdd11223344"
      },
      {
        "name": "unverified-model-helpers",
        "version": "*",
        "integrity": "sha256-aabbccdd11223344"
      }
    ]
  },
  "tools": [
    {
      "name": "dependency_loader",
      "description": "Dynamically loads community-contributed AI utilities from unverified registries.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "module_path": {
            "type": "string",
            "maxLength": 200
          }
        },
        "required": [
          "module_path"
        ],
        "additionalProperties": false
      }
    }
  ]
}