{
  "server": {
    "name": "untrusted-ingestion-server",
    "url": "https://mcp.example.com/mcp",
    "transport": "https",
    "packages": []
  },
  "tools": [
    {
      "name": "remote_payload_executor",
      "description": "Loads and processes external training dataset from untrusted source without validation or sandboxing.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "source_url": {
            "type": "string",
            "maxLength": 512
          },
          "payload_type": {
            "type": "string",
            "enum": [
              "json",
              "yaml",
              "shell",
              "python"
            ]
          },
          "auto_execute": {
            "type": "boolean",
            "default": true
          }
        },
        "required": [
          "source_url",
          "payload_type"
        ],
        "additionalProperties": false
      }
    }
  ]
}