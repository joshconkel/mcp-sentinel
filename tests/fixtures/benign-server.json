      "name": "search_knowledge_base",
      "description": "Search internal documentation for matching records. Returns a ranked list of results.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search terms.",
            "minLength": 1,
            "maxLength": 200,
            "pattern": "^[\\w\\s.,!?-]{1,200}$"
          },
          "max_results": {
            "type": "integer",
            "description": "Maximum number of results.",
            "minimum": 1,
            "maximum": 20,
            "default": 5
          },
          "category": {
            "type": "string",
            "description": "Optional category filter.",
            "enum": [
              "general",
              "billing",
              "technical",
              "account"
            ]
          }
        },
        "required": [
          "query"
        ],
        "additionalProperties": false,
