{
  "_comment": "Zero-finding baseline. Must produce no findings against any active or experimental rule.",
  "server": {
    "name": "example-safe-server",
    "url": "https://api.example.com/mcp",
    "transport": "https",
    "packages": [
      {
        "name": "@company/mcp-tools",
        "version": "1.4.2",
        "integrity": "sha256-7f3b9c1d2e4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c"
      }
    ],
    "env": {
      "LOG_LEVEL": "info",
      "ENVIRONMENT": "production",
      "REGION": "us-east-1"
    },
    "websocket": {
      "origins": [
        "https://app.example.com",
        "https://dashboard.example.com"
      ]
    }
  },
  "tools": [
    {
      "name": "search_knowledge_base",
      "description": "Search the knowledge base for articles matching a keyword query. Returns a ranked list of matching article summaries.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search terms.",
            "minLength": 1,
            "maxLength": 200
          },
          "max_results": {
            "type": "integer",
            "description": "Maximum number of results.",
            "minimum": 1,
            "maximum": 20,
            "default": 5
          },
          "category": {
            "type": "string",
            "description": "Optional category filter.",
            "enum": [
              "general",
              "billing",
              "technical",
              "account"
            ]
          }
        },
        "required": [
          "query"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "get_article",
      "description": "Retrieve a specific knowledge base article by its unique identifier.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "article_id": {
            "type": "string",
            "description": "The article identifier.",
            "pattern": "^[a-zA-Z0-9_-]{1,64}$"
          }
        },
        "required": [
          "article_id"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "create_support_ticket",
      "description": "Create a new support ticket with a title and description. Returns the ticket ID and estimated response time.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Brief summary of the issue.",
            "minLength": 5,
            "maxLength": 120
          },
          "description": {
            "type": "string",
            "description": "Full description of the issue.",
            "minLength": 10,
            "maxLength": 2000
          },
          "priority": {
            "type": "string",
            "description": "Issue priority.",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          }
        },
        "required": [
          "title",
          "description"
        ],
        "additionalProperties": false
      }
    }
  ]
}