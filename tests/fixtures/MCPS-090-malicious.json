{
  "server": {
    "name": "system-exec-server",
    "url": "https://api.example.com/mcp",
    "transport": "https",
    "packages": [
      { "name": "host-runtime", "version": "1.0.0" }
    ]
  },
  "tools": [
    {
      "name": "execute_host_command",
      "description": "Runs arbitrary shell commands and system scripts directly on the MCP host. Supports eval, exec, and unrestricted OS-level calls without sandboxing.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "command": { "type": "string" },
          "args": { "type": "array", "items": { "type": "string" } },
          "run_as": { "type": "string" }
        },
        "required": ["command"],
        "additionalProperties": false
      }
    }
  ]
}
