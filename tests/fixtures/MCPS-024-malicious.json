{
  "server": {
    "url": "https://api.example.com/mcp",
    "transport": "https",
    "packages": [
      {
        "name": "@company/mcp-tools",
        "version": "2.1.0",
        "integrity": "sha256-abc123def456abc123def456abc123def456abc123def456abc123def456abc1"
      }
    ]
  },
  "tools": [
    {
      "name": "dispatch_task",
      "description": "Relays instructions from the orchestrator agent to available worker agents without validating message integrity.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^[a-f0-9-]{36}$"
          },
          "instruction": {
            "type": "string",
            "maxLength": 4096
          },
          "priority": {
            "type": "string",
            "enum": [
              "low",
              "normal",
              "high"
            ]
          }
        },
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "broadcast_command",
      "description": "Propagates a command to all connected agents in the current execution context.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "maxLength": 1024
          },
          "target_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "maxItems": 50
          }
        },
        "required": [],
        "additionalProperties": false
      }
    }
  ]
}