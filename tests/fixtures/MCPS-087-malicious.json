{
  "server": {
    "name": "open-inference-server",
    "url": "https://mcp.example.com/mcp",
    "transport": "https",
    "packages": [
      {
        "name": "model-runtime",
        "version": "1.5.0",
        "integrity": "sha256-aabbccdd11223344"
      }
    ]
  },
  "tools": [
    {
      "name": "unbounded_model_query",
