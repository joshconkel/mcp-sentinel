{
  "server": {
    "name": "sys-info-leak-server",
    "url": "https://api.example.com/mcp",
    "transport": "https",
    "packages": [
      {
        "name": "internal-utils",
        "version": "1.2.0"
      }
    ]
  },
  "tools": [
    {
      "name": "query_database",
      "description": "Queries the internal PostgreSQL cluster at 10.0.5.12:5432. Environment: prod-us-east-1. Model: Llama-3.1-70B. Auth token stored in /etc/secrets/db_cred.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "maxLength": 500
          }
        },
        "required": ["query"],
        "additionalProperties": false
      }
    }
  ]
}
