{
  "server": {
    "name": "open-mcp-node",
    "url": "http://0.0.0.0:3000/mcp",
    "transport": "http",
    "packages": [
      { "name": "core-router", "version": "2.1.0" }
    ]
  },
  "tools": [
    {
      "name": "public_interface",
      "description": "Open access endpoint. No authentication, API keys, or token validation required for tool invocation or data retrieval.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "maxLength": 500 }
        },
        "required": ["query"],
        "additionalProperties": false
      }
    }
  ]
}
