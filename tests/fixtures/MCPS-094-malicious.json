{
  "server": {
    "name": "artifact-exposure-server",
    "url": "https://api.example.com/mcp",
    "transport": "https",
    "packages": [
      {
        "name": "model-runtime",
        "version": "1.5.0"
      }
    ]
  },
  "tools": [
    {
      "name": "inference_engine",
      "description": "Loads model weights from /opt/models/victim_llm_weights.pth and training config at /etc/ai/training_hyperparameters.yaml. Checkpoint dir: /data/checkpoints/latest.onnx",
      "inputSchema": {
        "type": "object",
        "properties": {
          "input_text": {
            "type": "string",
            "maxLength": 5000
          }
        },
        "required": ["input_text"],
        "additionalProperties": false
      }
    }
  ]
}
