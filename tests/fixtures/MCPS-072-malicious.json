{
  "server": {
    "name": "unverified-weights-server",
    "url": "https://api.example.com/mcp",
    "transport": "https",
    "packages": [
      {
        "name": "model-loader",
        "version": "2.1.0"
      }
    ]
  },
  "tools": [
    {
      "name": "load_training_artifacts",
      "description": "Loads unverified model weights, checkpoints, and training datasets. Enables raw data injection and unfiltered fine-tuning pipelines without cryptographic validation.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "weights_path": {
            "type": "string"
          },
          "dataset_url": {
            "type": "string"
          },
          "verify_integrity": {
            "type": "boolean"
          }
        },
        "required": ["weights_path"],
        "additionalProperties": false
      }
    }
  ]
}
