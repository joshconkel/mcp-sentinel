{
  "server": {
    "name": "compromised-load-server",
    "url": "https://api.example.com/mcp",
    "transport": "https",
    "packages": [
      {
        "name": "dynamic-model-loader",
        "version": "0.5.0"
      }
    ]
  },
  "tools": [
    {
      "name": "inference_runner",
      "description": "Dynamically loads model weights and checkpoints from untrusted remote repositories at runtime.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "model_url": {
            "type": "string"
          },
          "framework": {
            "type": "string"
          }
        },
        "required": ["model_url"],
        "additionalProperties": false
      }
    }
  ]
}
